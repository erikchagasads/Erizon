# ══════════════════════════════════════════════════════════════
#  ERIZON — Variáveis de Ambiente
#  Copie este arquivo para .env.local e preencha os valores.
#  NUNCA commite .env.local ou qualquer arquivo com valores reais.
# ══════════════════════════════════════════════════════════════

# ─── Supabase (obrigatório) ───────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NUNCA expor no browser

# ─── App URL (obrigatório) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://erizon.vercel.app

# ─── Groq — Copiloto AI (obrigatório) ────────────────────────
# console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# ─── Meta Ads (obrigatório para sync de campanhas) ────────────
# developers.facebook.com → seu app
META_APP_ID=000000000000000
META_APP_SECRET=abc123...

# ─── Telegram — Alertas (recomendado) ────────────────────────
# 1. Crie um bot com @BotFather → /newbot
# 2. Obtenha seu chat ID com @userinfobot
TELEGRAM_BOT_TOKEN=0000000000:AAF...
TELEGRAM_CHAT_ID=000000000

# ─── Stripe — Billing (necessário para cobrar) ────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Products → IDs dos preços (price_xxx)
STRIPE_PRICE_GESTOR=price_...
STRIPE_PRICE_AGENCIA=price_...

# ─── Segurança — Crons e Webhooks ────────────────────────────
# Gere com: openssl rand -hex 32
CRON_SECRET=
WORKER_SECRET=
WEBHOOK_SECRET=        # Token para webhook de leads (n8n)

# ─── Google Analytics 4 (opcional) ───────────────────────────
# Necessário para o conector GA4 enriquecer receita
GA4_PROPERTY_ID=000000000
GOOGLE_CLIENT_EMAIL=service-account@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Shopify (opcional) ───────────────────────────────────────
SHOPIFY_STORE_DOMAIN=minhaloja.myshopify.com
# SHOPIFY_ACCESS_TOKEN=shpat_...

# ─── Hotmart (opcional) ───────────────────────────────────────
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=
HOTMART_BASIC_TOKEN=

# ─── Autopilot (padrão seguro = simulation) ──────────────────
# Valores: simulation | live
# Em simulation: decisões são registradas mas não executadas na Meta
ERIZON_AUTOPILOT_MODE=simulation

# ─── Anthropic (opcional — fallback de AI) ───────────────────
# Necessário apenas se quiser trocar Groq por Claude em alguma rota
ANTHROPIC_API_KEY=sk-ant-...
