# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://seu-dominio.vercel.app

# ─── IA ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
GROQ_API_KEY=gsk_your-key-here

# ─── Meta Ads ────────────────────────────────────────────────────────────────
# META_ACCESS_TOKEN está DEPRECADO — tokens são armazenados por workspace
# na tabela ad_accounts.access_token. Não configure essa variável global
# para não bypassar a segurança por workspace acidentalmente.
# META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=act_your-ad-account-id
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Secret key: Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_your-stripe-key
# Webhook secret: Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Price IDs: Dashboard → Products (um por plano)
STRIPE_PRICE_CORE=price_your-core-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_COMMAND=price_your-command-price-id

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_API_KEY=your-evolution-api-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:suporte@seudominio.com

# ─── Google / GA4 (opcional) ─────────────────────────────────────────────────
# GA=G-XXXXXXXXXX
# GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Hotmart (opcional) ───────────────────────────────────────────────────────
# HOTMART_CLIENT_ID=your-hotmart-client-id
# HOTMART_CLIENT_SECRET=your-hotmart-client-secret
# HOTMART_BASIC_TOKEN=your-hotmart-basic-token

# ─── Shopify (opcional) ───────────────────────────────────────────────────────
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# ─── Secrets internos (gere com: openssl rand -hex 32) ───────────────────────
CRON_SECRET=your-cron-secret-here
BLOG_AUTOMATION_ENABLED=true
BLOG_AUTO_PUBLISH=false
BLOG_CRON_SECRET=your-blog-cron-secret-here
BLOG_GENERATION_TIME=08:00
BLOG_TIMEZONE=America/Sao_Paulo
BLOG_MARKET_RSS_FEEDS=OpenAI News|https://openai.com/news/rss.xml,Meta Newsroom|https://about.fb.com/news/category/product-news/feed/,Google Ads & Commerce|https://blog.google/products/ads-commerce/rss/
WORKER_SECRET=your-worker-secret-here
WEBHOOK_SECRET=your-webhook-secret-here

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=seu@email.com

# ─── Autopilot ───────────────────────────────────────────────────────────────
# "enabled" = ações automáticas | qualquer outro valor = só sugere
ERIZON_AUTOPILOT_MODE=disabled

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Crie a conta em resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your-resend-api-key
# Remetente: deve usar domínio verificado no Resend (ou onboarding@resend.dev para testes)
FROM_EMAIL=Erizon <noreply@seudominio.com>

# ─── Observabilidade ─────────────────────────────────────────────────────────
LOG_LEVEL=info
